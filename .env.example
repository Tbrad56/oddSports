# Get a key at https://the-odds-api.com (never commit the real one)
ODDS_API_KEY=
PORT=3000
# Minutes to reuse cached odds/props before spending fresh credits (default 10;
# raise to 30-60 if you're burning through your monthly quota)
ODDS_CACHE_MINUTES=10

# Signs the lock-screen login session cookie. Set this to a long random
# string (e.g. `openssl rand -hex 32`) so logins survive a restart/redeploy.
# If left blank, a random secret is generated at boot — the app still works,
# it just signs everyone out every time the server restarts.
SESSION_SECRET=
