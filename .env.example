# Get a key at https://the-odds-api.com (never commit the real one)
ODDS_API_KEY=
PORT=3000
# Minutes to reuse cached odds/props before spending fresh credits (default 10;
# raise to 30-60 if you're burning through your monthly quota)
ODDS_CACHE_MINUTES=10

# Signs the lock-screen login session cookie. Set this to a long random
# string (e.g. `openssl rand -hex 32`) so logins survive a restart/redeploy.
# If left blank, a random secret is generated at boot — the app still works,
# it just signs everyone out every time the server restarts.
SESSION_SECRET=

# Telegram push notifications (Value Finder edges -> your phone). Both must
# be set or notifications stay off entirely — nothing runs, no extra Odds
# API spend, if you skip this section.
#   1. Message @BotFather on Telegram, /newbot, copy the token it gives you.
#   2. Send your new bot any message, then visit
#      https://api.telegram.org/bot<TOKEN>/getUpdates and copy the
#      "chat":{"id": ...} number from the response.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# How often to scan for value edges, in minutes (min 15, default 60). This is
# the ONE real cost: with nobody browsing the site, this scan is the only
# thing hitting the Odds API — one credit per sport per interval, on top of
# normal usage. Lower = fresher alerts but more credits burned unattended.
NOTIFY_SCAN_MINUTES=60
# Comma-separated Odds API sport keys to scan. Fewer sports = less quota spent.
NOTIFY_SPORTS=americanfootball_nfl,basketball_nba,baseball_mlb
